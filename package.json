{
  "name": "logpeak",
  "displayName": "Log Peak",
  "description": "A low-profile TXT reader shell for the VS Code bottom panel.",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:logPeak.panelView",
    "onCommand:logPeak.toggleBossMode"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "logPeak",
          "title": "Log Peak",
          "icon": "media/logpeak.svg"
        }
      ]
    },
    "views": {
      "logPeak": [
        {
          "id": "logPeak.panelView",
          "name": "Log Peak",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "logPeak.toggleBossMode",
        "title": "Toggle Boss Mode",
        "category": "Log Peak"
      }
    ],
    "keybindings": [
      {
        "command": "logPeak.toggleBossMode",
        "key": "ctrl+alt+`",
        "mac": "cmd+alt+`",
        "when": "logPeak.visible"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "logPeak.toggleBossMode",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test tests/**/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.7.2"
  }
}
